# Stripe 配置
# 请从 Stripe Dashboard 获取以下密钥

# Stripe Secret Key (测试环境)
# 访问: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Webhook Secret
# 访问: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Publishable Key (前端使用)
# 访问: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# 服务器配置
PORT=3001
NODE_ENV=development

# Webhook 端点 URL
WEBHOOK_ENDPOINT_URL=http://localhost:3001/api/webhook
