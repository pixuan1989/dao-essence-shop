{
  "framework": null,
  "trailingSlash": false,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/auth", "destination": "/api/auth" },
    { "source": "/callback", "destination": "/api/callback" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "dao-essence-shop.vercel.app"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "daoessentia.com"
        }
      ]
    }
  ]
}
