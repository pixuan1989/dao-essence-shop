{
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": ".",
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/docs/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*\\.(?:md|cjs|ps1|sh|bat|py))",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "dao-essence-shop.vercel.app"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "daoessentia.com"
        }
      ]
    }
  ]
}
