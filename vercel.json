{
  "framework": null,
  "trailingSlash": false,
  "installCommand": "npm install",
  "buildCommand": "node build-blog.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/auth", "destination": "/api/auth" },
    { "source": "/callback", "destination": "/api/callback" },
    { "source": "/blog/:path", "destination": "/blog/:path.html" },
    { "source": "/:path", "destination": "/:path.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "dao-essence-shop.vercel.app"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "daoessentia.com"
        }
      ]
    }
  ]
}
