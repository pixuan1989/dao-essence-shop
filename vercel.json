{
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": ".",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/culture", "destination": "/culture.html" },
    { "source": "/guide", "destination": "/guide.html" },
    { "source": "/destiny", "destination": "/destiny.html" },
    { "source": "/bazi-form", "destination": "/bazi-form.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },

    {
      "source": "/(.*\\.(?:md|cjs|ps1|sh|bat|py))",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "dao-essence-shop.vercel.app"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://www.daoessentia.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "daoessentia.com"
        }
      ]
    }
  ]
}
